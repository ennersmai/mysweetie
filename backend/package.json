    "dev:watch": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postbuild": "echo Build completed successfully",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
